rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow create: if owns(userId) && request.resource.data.uid == userId;
      allow get: if owns(userId);

      // Leaderboards need ranked user reads. A production app should use a separate
      // public profile collection or trusted server logic to avoid exposing private fields.
      allow list: if true;

      allow update: if owns(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    match /attempts/{attemptId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /badges/{badgeId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /dailyChallenges/{date} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
